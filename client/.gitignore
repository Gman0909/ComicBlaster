# Mirror of ../web/dist/ written by scripts/prepare-frontend.ps1 right
# before each Wails build. Not source; never commit.
/frontend/dist/
/dist/

# Wails build artifacts (.exe, .app bundles, generated per-platform
# icons, NSIS installer template). Everything under build/ is
# regenerated on each `wails build` from the single committed source:
#   build/appicon.png  — the app icon. Wails reads this on every
#                         build and regenerates .ico (Windows) and
#                         .icns (macOS) from it.
/build/bin/
/build/windows/
/build/darwin/
/build/linux/

# Wails caches the frontend install state next to package.json.
/frontend/package.json.md5

# Auto-generated TypeScript bindings (regenerated by `wails generate`).
/bindings/
